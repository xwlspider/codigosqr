{
  "expo": {
    "name": "codigosqr",
    "slug": "codigosqr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/staylyLogo.png",
    "scheme": "codigosqr",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
       
        "foregroundImage": "./assets/images/staylyLogo.png"

      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/staylyLogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/staylyLogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "recordAudioPermission": false,
          "cameraPermission": "Permite escanear códigos QR de comprobantes."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
